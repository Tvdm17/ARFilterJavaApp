<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Layout for the main AR camera screen (screenshots + filter navigation)
    ===========================================================================================
    Two layers stacked on top of each other:
      1. SurfaceView (full screen) — [DEEPAR] DeepAR renders the AR camera feed here
      2. RelativeLayout (full screen overlay) — [ANDROID] All UI controls sit on top

    Video recording is handled by activity_preview.xml / PreviewActivity.

    CRITICAL: The SurfaceView id="@+id/surface" must not be removed.
    It is registered in MainActivity.setupViews() as the DeepAR render target.
-->

<!-- [ANDROID] Outer ConstraintLayout: full-screen container. -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!--
        [DEEPAR] SurfaceView — the AR rendering surface.
        DeepAR renders the camera feed + AR effects directly into this surface.
        It sits behind all other views (defined first = lower z-order).
    -->
    <SurfaceView
        android:id="@+id/surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!--
        [ANDROID] RelativeLayout overlay: sits on top of the SurfaceView.
        All UI controls live here.
    -->
    <RelativeLayout
        android:id="@+id/relativeLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!--
            Center-bottom: Screenshot button.
            Click → deepARManager.takeScreenshot()
        -->
        <ImageButton
            android:id="@+id/screenshotButton"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="40dp"
            android:background="@null"
            android:scaleType="centerInside"
            android:src="@drawable/record_selector"
            android:contentDescription="Take screenshot" />

        <!--
            Top-left: Switch camera (front ↔ back).
            Click → cameraManager.switchCamera()
        -->
        <ImageButton
            android:id="@+id/switchCamera"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_marginStart="15dp"
            android:layout_marginTop="15dp"
            android:background="@null"
            android:scaleType="centerInside"
            android:src="@drawable/camera_white"
            android:contentDescription="Switch camera" />

        <!--
            Bottom-left: Previous filter arrow.
            Click → deepARManager.gotoPrevious()
        -->
        <ImageButton
            android:id="@+id/previousMask"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="20dp"
            android:background="@null"
            android:scaleType="centerInside"
            android:src="@drawable/arrow_left"
            android:contentDescription="Previous filter" />

        <!--
            Bottom-right: Next filter arrow.
            Click → deepARManager.gotoNext()
        -->
        <ImageButton
            android:id="@+id/nextMask"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            android:background="@null"
            android:scaleType="centerInside"
            android:src="@drawable/arrow_right"
            android:contentDescription="Next filter" />

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
