<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/backgroundPrimary">

    <TextView
        android:id="@+id/tvFilterTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filter_title"
        android:textColor="@color/textPrimary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupFilters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="false"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="8dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAverageLook"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/filter_average_look"
            android:textSize="14sp"
            android:checkable="true"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            app:chipBackgroundColor="@color/backgroundSecondary"
            app:checkedIconTint="@color/colorPrimary"
            app:chipStrokeColor="@color/colorPrimary"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipNatural"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/filter_natural"
            android:textSize="14sp"
            android:checkable="true"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            app:chipBackgroundColor="@color/backgroundSecondary"
            app:checkedIconTint="@color/colorPrimary"
            app:chipStrokeColor="@color/colorPrimary"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipMedium"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/filter_medium"
            android:textSize="14sp"
            android:checkable="true"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            app:chipBackgroundColor="@color/backgroundSecondary"
            app:checkedIconTint="@color/colorPrimary"
            app:chipStrokeColor="@color/colorPrimary"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipBright"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/filter_bright"
            android:textSize="14sp"
            android:checkable="true"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            app:chipBackgroundColor="@color/backgroundSecondary"
            app:checkedIconTint="@color/colorPrimary"
            app:chipStrokeColor="@color/colorPrimary"
            app:chipStrokeWidth="1dp" />

    </com.google.android.material.chip.ChipGroup>

    <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="28dp">

        <Button
            android:id="@+id/btnClearFilter"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/btn_clear"
            android:textSize="15sp"
            android:textColor="@color/textPrimary"
            android:backgroundTint="@color/buttonDisabled"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnApplyFilter"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/btn_apply"
            android:textSize="15sp"
            android:textColor="@color/textOnGold"
            android:backgroundTint="@color/buttonPrimary"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
