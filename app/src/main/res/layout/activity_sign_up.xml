<?xml version="1.0" encoding="utf-8"?>
    <!--
        activity_sign_up.xml — Layout for the Sign Up screen
        ======================================================
        Colors:  res/values/colors.xml
                 (C:\Users\Admin\StudioProjects\305\app\src\main\res\values\colors.xml)

        ADDING ACTIVITIES / LOGIC LATER:
        - Back / already have account : find "TODO: Navigate to SignInActivity"
        - Terms of Services link      : find "TODO: Navigate to TermsActivity"
        - Privacy Policy link         : find "TODO: Navigate to PrivacyPolicyActivity"
        - Continue button             : find "TODO: Navigate to next onboarding screen"
        - Customer/Creator toggle     : find "TODO: Handle Customer/Creator toggle" in your Activity

        VIEW IDs (reference these in your Activity/Fragment):
        - @+id/tvSignUpTitle      — "Sign Up" heading
        - @+id/etEmail            — email EditText
        - @+id/etPassword         — password EditText
        - @+id/cbTerms            — terms & privacy CheckBox
        - @+id/tvTermsText        — static part: "I agree to the"
        - @+id/tvTermsLink        — "Terms of Services" clickable link
        - @+id/tvTermsAnd         — static " and "
        - @+id/tvPrivacyLink      — "Privacy Policy." clickable link
        - @+id/btnCustomer        — Customer toggle button
        - @+id/btnCreator         — Creator toggle button
        - @+id/tvOr               — "Or" separator label
        - @+id/btnContinue        — Continue button
        - @+id/tvHaveAccount      — "Have an Account?" label
        - @+id/tvSignIn           — "Sign In" clickable link
    -->

    <ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".SignUpActivity">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="56dp"
            android:paddingBottom="40dp">

            <!-- ══════════════════════════════════════
                 HEADING
                 ══════════════════════════════════════ -->

            <TextView
                android:id="@+id/tvSignUpTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign Up"
                android:textColor="@color/textPrimary"
                android:textSize="30sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- ══════════════════════════════════════
                 EMAIL FIELD
                 ══════════════════════════════════════ -->

            <TextView
                android:id="@+id/tvEmailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="@color/colorPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/tvSignUpTitle"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:hint="Your email address"
                android:textColorHint="@color/textMuted"
                android:textColor="@color/textPrimary"
                android:textSize="15sp"
                android:inputType="textEmailAddress"
                android:background="@null"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingBottom="8dp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvEmailLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/dividerEmail"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="@color/divider"
                app:layout_constraintTop_toBottomOf="@id/etEmail"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ══════════════════════════════════════
                 PASSWORD FIELD
                 ══════════════════════════════════════ -->

            <TextView
                android:id="@+id/tvPasswordLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textColor="@color/colorPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/dividerEmail"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:hint="Your password"
                android:textColorHint="@color/textMuted"
                android:textColor="@color/textPrimary"
                android:textSize="15sp"
                android:inputType="textPassword"
                android:background="@null"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingBottom="8dp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/dividerPassword"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:background="@color/divider"
                app:layout_constraintTop_toBottomOf="@id/etPassword"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ══════════════════════════════════════
                 TERMS & PRIVACY CHECKBOX ROW
                 Laid out as: [CheckBox] [TextView chain]
                 The TextView chain is wrapped in a horizontal LinearLayout
                 so the mixed-style text sits neatly next to the checkbox.
                 ══════════════════════════════════════ -->

            <!--
                CheckBox — user must tick before continuing.
                In your Activity:
                    cbTerms = findViewById(R.id.cbTerms)
                    cbTerms.isChecked  ← read this before allowing Continue
            -->
            <CheckBox
                android:id="@+id/cbTerms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/colorPrimary"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/dividerPassword"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/llTermsText" />

            <!--
                LinearLayout holding the terms text chain.
                Mixed colours achieved via separate TextViews inside one row.
            -->
            <LinearLayout
                android:id="@+id/llTermsText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:flexDirection="row"
                android:flexWrap="wrap"
                android:layout_marginStart="8dp"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/dividerPassword"
                app:layout_constraintStart_toEndOf="@id/cbTerms"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- "I agree to the " -->
                <TextView
                    android:id="@+id/tvTermsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="I agree to the "
                    android:textColor="@color/textSecondary"
                    android:textSize="13sp" />

                <!--
                    "Terms of Services"
                    TODO: Navigate to TermsActivity
                    In your Activity:
                        tvTermsLink = findViewById(R.id.tvTermsLink)
                        tvTermsLink.setOnClickListener {
                            // startActivity(Intent(this, TermsActivity::class.java))
                        }
                -->
                <TextView
                    android:id="@+id/tvTermsLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Terms of Services"
                    android:textColor="@color/textGold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- " and " -->
                <TextView
                    android:id="@+id/tvTermsAnd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" and "
                    android:textColor="@color/textSecondary"
                    android:textSize="13sp" />

                <!--
                    "Privacy Policy."
                    TODO: Navigate to PrivacyPolicyActivity
                    In your Activity:
                        tvPrivacyLink = findViewById(R.id.tvPrivacyLink)
                        tvPrivacyLink.setOnClickListener {
                            // startActivity(Intent(this, PrivacyPolicyActivity::class.java))
                        }
                -->
                <TextView
                    android:id="@+id/tvPrivacyLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Privacy Policy."
                    android:textColor="@color/textGold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- ══════════════════════════════════════
                 CUSTOMER / CREATOR TOGGLE BUTTONS
                 ══════════════════════════════════════
                 TODO: Handle Customer/Creator toggle
                 In your Activity:
                     btnCustomer = findViewById(R.id.btnCustomer)
                     btnCreator  = findViewById(R.id.btnCreator)

                     // Default state: Customer selected
                     setCustomerSelected(true)

                     fun setCustomerSelected(customerActive: Boolean) {
                         btnCustomer.backgroundTintList = ColorStateList.valueOf(
                             ContextCompat.getColor(this,
                                 if (customerActive) R.color.buttonPrimary else R.color.buttonDisabled))
                         btnCustomer.setTextColor(ContextCompat.getColor(this,
                                 if (customerActive) R.color.textOnGold  else R.color.textSecondary))
                         btnCreator.backgroundTintList = ColorStateList.valueOf(
                             ContextCompat.getColor(this,
                                 if (customerActive) R.color.buttonDisabled else R.color.buttonPrimary))
                         btnCreator.setTextColor(ContextCompat.getColor(this,
                                 if (customerActive) R.color.textSecondary  else R.color.textOnGold))
                     }

                     btnCustomer.setOnClickListener { setCustomerSelected(true)  }
                     btnCreator .setOnClickListener { setCustomerSelected(false) }
            -->

            <!-- Customer button — gold by default (selected state) -->
            <Button
                android:id="@+id/btnCustomer"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:text="Customer"
                android:textColor="@color/textOnGold"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/buttonPrimary"
                android:layout_marginTop="28dp"
                app:layout_constraintTop_toBottomOf="@id/llTermsText"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- "Or" separator -->
            <TextView
                android:id="@+id/tvOr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Or"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/btnCustomer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Creator button — grey by default (unselected state) -->
            <Button
                android:id="@+id/btnCreator"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:text="Creator"
                android:textColor="@color/textSecondary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/buttonDisabled"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tvOr"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ══════════════════════════════════════
                 CONTINUE BUTTON
                 ══════════════════════════════════════ -->

            <!--
                TODO: Navigate to next onboarding screen
                In your Activity:
                    btnContinue = findViewById(R.id.btnContinue)
                    btnContinue.setOnClickListener {
                        // validate fields + cbTerms.isChecked, then:
                        // startActivity(Intent(this, OnboardingActivity::class.java))
                    }
            -->
            <Button
                android:id="@+id/btnContinue"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:text="Continue"
                android:textColor="@color/textOnGold"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/buttonPrimary"
                android:layout_marginTop="28dp"
                app:layout_constraintTop_toBottomOf="@id/btnCreator"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ══════════════════════════════════════
                 SIGN IN LINK (bottom)
                 ══════════════════════════════════════ -->

            <TextView
                android:id="@+id/tvHaveAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Have an Account?"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/btnContinue"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintHorizontal_bias="0.5" />

            <!--
                TODO: Navigate to SignInActivity
                In your Activity:
                    tvSignIn = findViewById(R.id.tvSignIn)
                    tvSignIn.setOnClickListener {
                        // startActivity(Intent(this, SignInActivity::class.java))
                    }
            -->
            <TextView
                android:id="@+id/tvSignIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign In"
                android:textColor="@color/textGold"
                android:textSize="13sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="32dp"
                android:layout_marginStart="6dp"
                app:layout_constraintTop_toBottomOf="@id/btnContinue"
                app:layout_constraintStart_toEndOf="@id/tvHaveAccount"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_chainStyle="packed" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>