<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="16dp"
    android:background="@color/backgroundPrimary">

    <!-- Item image — 200x200dp square -->
    <ImageView
        android:id="@+id/ivItemImage"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        android:background="@color/backgroundSecondary"
        android:contentDescription="Item image"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Item name -->
    <TextView
        android:id="@+id/tvItemName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/textPrimary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/ivItemImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        "View" button.
        TODO: Navigate to activity_item_card (wire up in ShopAdapter — see header)
    -->
    <Button
        android:id="@+id/btnView"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="View"
        android:textColor="@color/textOnGold"
        android:textSize="13sp"
        android:backgroundTint="@color/buttonPrimary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvItemName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Star rating bar — read-only display of average rating.
        TODO: Show average rating tooltip (wire up in ShopAdapter — see header)
        Tapping shows/hides tvRatingValue below.
    -->
    <RatingBar
        android:id="@+id/rbRating"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="0.5"
        android:isIndicator="false"
        android:progressTint="@color/colorPrimary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Numeric rating tooltip — hidden by default.
        Shown when user taps the RatingBar.
        Displays the double average value e.g. "3.5"
    -->
    <TextView
        android:id="@+id/tvRatingValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/backgroundDark"
        android:textColor="@color/textOnDark"
        android:textSize="12sp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        android:text="0.0"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/rbRating"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>